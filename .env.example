PORT=7001
HOST=127.0.0.1

# Debrid: lascia vuoto per disabilitare il provider.
# Se entrambi sono valorizzati, RealDebrid ha la precedenza.
REALDEBRID_API_KEY=
TORBOX_API_KEY=

# Numero massimo di stream restituiti per richiesta
MAX_RESULTS=15

# === Upstream community addons (Stremio backends called by /stream) ===
# Tutti DISABILITATI di default per rispetto verso i maintainer originali.
# Se vuoi abilitarli, deploya la TUA istanza di ciascun upstream (sono tutti
# open-source) e metti qui l'URL. Vedi sezione "Credits / Upstream services"
# del README per i link ai repo e indicazioni docker-compose.
#
# StremThru — github.com/MunifTanjim/stremthru
# STREMTHRU_URL=http://your-stremthru-host:8080/stremio/torz/<base64-config-IT>
# STREMTHRU_URL_EN=http://your-stremthru-host:8080/stremio/torz/<base64-config-EN>
#
# Comet — github.com/g0ldyy/comet
# COMET_URL=http://your-comet-host:8000/<base64-config-IT>
# COMET_URL_EN=http://your-comet-host:8000/<base64-config-EN>
#
# MediaFusion — github.com/mhdzumair/MediaFusion
# MEDIAFUSION_URL=http://your-mediafusion-host:8000
# MEDIAFUSION_HOST=http://your-mediafusion-host:8000
#
# Meteor (closed-source, non self-hostable):
# METEOR_URL=https://meteorfortheweebs.midnightignite.me/<base64-config-IT>
# METEOR_URL_EN=https://meteorfortheweebs.midnightignite.me/<base64-config-EN>
#
# Torrentio (open community mirror, attivo di default):
# TORRENTIO_URL=https://torrentio.strem.fun/...

# === Extra catalog (Netflix/Prime/Disney+ etc. via TMDB) ===
# Registrazione gratuita: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# === Admin ===
ADMIN_TOKEN=

# === Discord changelog poster (scripts/changelog-discord.js) ===
# Webhook del canale: Discord → impostazioni canale → Integrazioni → Webhook.
DISCORD_CHANGELOG_WEBHOOK=
# Lingua dei post: en | it | both  (default en)
CHANGELOG_LANG=en

# === Discord status monitor (scripts/status-discord.js) ===
# Webhook del canale #status (separato da quello del changelog).
DISCORD_STATUS_WEBHOOK=
